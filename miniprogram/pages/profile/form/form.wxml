<view class="container pb">
  <view class="card">
    <button open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" class="primary-btn full">微信授权手机号</button>
    <button class="secondary-btn full2" bindtap="onGetNickname">获取微信昵称</button>

    <form-item label="手机号" required>
      <input class="input readonly" disabled value="{{form.phone || '请先授权手机号'}}" />
    </form-item>

    <form-item label="姓名" required>
      <input class="input" value="{{form.realName}}" data-field="realName" bindinput="onInput" placeholder="默认使用微信昵称，可手动调整" />
    </form-item>

    <form-item label="性别" required>
      <picker mode="selector" range="{{genders}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker">{{genderIndex >= 0 ? genders[genderIndex].label : '请选择性别'}}</view>
      </picker>
    </form-item>

    <form-item label="年龄" required>
      <picker mode="selector" range="{{ages}}" value="{{ageIndex}}" bindchange="onAgeChange">
        <view class="picker">{{ageIndex >= 0 ? ages[ageIndex] : '请选择年龄'}}</view>
      </picker>
    </form-item>

    <form-item label="职业">
      <input class="input" value="{{form.job}}" data-field="job" bindinput="onInput" placeholder="请输入职业" />
    </form-item>

    <form-item label="收入区间">
      <picker mode="selector" range="{{incomes}}" range-key="label" value="{{incomeIndex}}" bindchange="onIncomeChange">
        <view class="picker">{{incomeIndex >= 0 ? incomes[incomeIndex].label : '请选择收入区间'}}</view>
      </picker>
    </form-item>

    <checkbox-group bindchange="onPolicyChange">
      <label class="privacy"><checkbox value="agree" checked="{{form.agreePolicy}}" />我已阅读并同意《隐私政策》</label>
    </checkbox-group>
  </view>

  <submit-bar loading="{{loading}}" disabled="{{submitDisabled}}" text="{{isEdit ? '更新资料' : '提交资料'}}" bind:submit="onSubmit" />
</view>
