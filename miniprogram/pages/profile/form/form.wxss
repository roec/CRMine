.pb { padding-bottom: 180rpx; }
.input, .picker, .auth-field {
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #dbe2ea;
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #0f172a;
  background: #fff;
  box-sizing: border-box;
}

.auth-field {
  position: relative;
  display: flex;
  align-items: center;
}

.auth-text { font-size: 28rpx; }
.placeholder { color: #94a3b8; }

.auth-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  border: 0;
  background: transparent;
  opacity: 0;
}

.privacy { margin-top: 20rpx; display: flex; align-items: center; color: #475569; font-size: 24rpx; }
